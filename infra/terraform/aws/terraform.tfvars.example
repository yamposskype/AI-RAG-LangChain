region                       = "us-east-1"
project                      = "rag-system"
cluster_name                 = "rag-system-prod"
kubernetes_version           = "1.29"
cluster_endpoint_public_access  = true
cluster_endpoint_private_access = true
enable_cluster_encryption    = true
cluster_log_retention_days   = 30

vpc_cidr                 = "10.0.0.0/16"
public_subnet_cidrs      = ["10.0.0.0/20", "10.0.16.0/20", "10.0.32.0/20"]
private_subnet_cidrs     = ["10.0.48.0/20", "10.0.64.0/20", "10.0.80.0/20"]

node_group_instance_types = ["m6i.large"]
node_group_capacity_type  = "ON_DEMAND"
node_group_disk_size      = 120
node_group_desired_size   = 3
node_group_min_size       = 2
node_group_max_size       = 10
enable_canary_node_group  = true
canary_node_group_instance_types = ["t3.large"]
canary_node_group_desired_size   = 1
canary_node_group_min_size       = 1
canary_node_group_max_size       = 4

ecr_scan_on_push             = true
ecr_keep_tagged_image_count  = 40
ecr_keep_untagged_image_count = 5

tags = {
  Environment = "production"
  Project     = "rag-system"
  Owner       = "platform-team"
}
